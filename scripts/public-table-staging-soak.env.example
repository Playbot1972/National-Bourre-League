# Phase 3 public-table staging soak — copy to .env.soak (or export manually).
# Staging only. Do not point at production without explicit approval.

# Required
SOAK_ENV=staging
SOAK_FIREBASE_API_KEY=your-web-api-key
SOAK_FIREBASE_PROJECT_ID=your-staging-project-id
SOAK_HOST_EMAIL=soak-host@example.com
SOAK_HOST_PASSWORD=
SOAK_GUEST_EMAIL=soak-guest@example.com
SOAK_GUEST_PASSWORD=

# Optional
SOAK_FIREBASE_AUTH_DOMAIN=your-staging-project-id.firebaseapp.com
SOAK_FIREBASE_APP_ID=
SOAK_FUNCTIONS_REGION=us-central1
SOAK_CYCLES=1
SOAK_DELAY_MS=500
SOAK_START_CYCLE=1
SOAK_LOG_CSV=artifacts/public-table-soak/soak-log.csv
SOAK_LOG_MD=artifacts/public-table-soak/soak-log.md

# Local emulator (SOAK_USE_EMULATOR=1) — used by npm run soak:public-table:emulator
# SOAK_USE_EMULATOR=1
# SOAK_FIREBASE_PROJECT_ID=demo-national-bourre-league
# SOAK_FIREBASE_API_KEY=fake-api-key
