rules_version = '2';

// Firestore security rules — National Bourré League social app.
//
// Game state (currentHand, handEnrollment, privateHands, hand ledger, score nets)
// is written only by Cloud Functions (Admin SDK). Room members may read live state.

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isUser(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isMember(roomId) {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/roomMembers/$(roomId + '_' + request.auth.uid));
    }

    function isRoomOwner(roomId) {
      return isSignedIn() &&
        get(/databases/$(database)/documents/rooms/$(roomId)).data.ownerId == request.auth.uid;
    }

    // Session fields mutated only by Cloud Functions during deal/draw/play/settlement.
    function sessionGameFieldsChanged() {
      return request.resource.data.diff(resource.data).affectedKeys().hasAny([
        'currentHand',
        'handEnrollment',
        'handCount',
        'carryOverPot',
        'dealerId',
        'pendingCoWinSettlement',
        'handStakeLocked',
      ]);
    }

    // Room members may drive I'm-in / timeout while enrollment is active (client fallback
    // when Cloud Functions are unavailable). Deal completion removes handEnrollment.
    function memberEnrollmentSessionUpdate() {
      let changed = request.resource.data.diff(resource.data).affectedKeys();
      return resource.data.get('handEnrollment', {}).get('active', false) == true
        && changed.hasOnly(['handEnrollment', 'currentHand', 'updatedAt'])
        && (
          request.resource.data.get('handEnrollment', {}).get('active', false) == true
          || request.resource.data.get('currentHand', {}).get('phase', '') == 'draw'
        );
    }

    function enrollmentActiveForSession(roomId, sessionId) {
      return get(/databases/$(database)/documents/rooms/$(roomId)/sessions/$(sessionId))
        .data.get('handEnrollment', {}).get('active', false) == true;
    }

    function scoreLedgerFieldsChanged() {
      return request.resource.data.diff(resource.data).affectedKeys().hasAny([
        'net',
        'tricksWon',
        'handsWon',
        'total',
        'skipNextAnte',
        'perHandStake',
      ]);
    }

    match /users/{uid} {
      allow read: if isSignedIn();
      allow write: if isUser(uid);
    }

    match /rooms/{roomId} {
      allow read: if isMember(roomId) || resource.data.ownerId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
      allow update, delete: if isRoomOwner(roomId);

      match /sessions/{sessionId} {
        allow read: if isMember(roomId);
        allow create: if isMember(roomId);
        allow update: if isMember(roomId)
          && (!sessionGameFieldsChanged() || memberEnrollmentSessionUpdate());
        allow delete: if isRoomOwner(roomId);

        match /scores/{scoreId} {
          allow read: if isMember(roomId);
          allow create: if isMember(roomId);
          allow update: if isMember(roomId) && !scoreLedgerFieldsChanged();
          allow delete: if isRoomOwner(roomId);
        }

        match /hands/{handId} {
          allow read: if isMember(roomId);
          allow write: if false;
        }

        match /privateHands/{playerId} {
          allow read: if isMember(roomId) && (
            request.auth.uid == playerId ||
            playerId.matches('bot_.*')
          );
          allow write: if isMember(roomId) && enrollmentActiveForSession(roomId, sessionId);
        }
      }
    }

    match /inviteLookups/{code} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.ownerId == request.auth.uid;
    }

    match /roomMembers/{memberId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    match /players/{playerId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }
  }
}
