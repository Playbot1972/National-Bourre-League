rules_version = '2';

// Firestore security rules — National Bourré League social app.
//
// Game state (currentHand, handEnrollment, privateHands, hand ledger, score nets)
// is written only by Cloud Functions (Admin SDK). Room members may read live state.

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isUser(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isMember(roomId) {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/roomMembers/$(roomId + '_' + request.auth.uid));
    }

    function isRoomOwner(roomId) {
      let roomRef = /databases/$(database)/documents/rooms/$(roomId);
      return isSignedIn() &&
        exists(roomRef) &&
        get(roomRef).data.ownerId == request.auth.uid;
    }

    // Session fields mutated only by Cloud Functions during deal/draw/play/settlement.
    function sessionGameFieldsChanged() {
      return request.resource.data.diff(resource.data).affectedKeys().hasAny([
        'currentHand',
        'handEnrollment',
        'handCount',
        'carryOverPot',
        'dealerId',
        'pendingCoWinSettlement',
        'handStakeLocked',
      ]);
    }

    function pagatHandRevealActive(data) {
      return data.get('currentHand', {}).get('phase', '') == 'reveal'
        && data.get('currentHand', {}).get('participantIds', []).size() > 0;
    }

    function pagatHandDrawActive(data) {
      return data.get('currentHand', {}).get('phase', '') == 'draw';
    }

    function pagatHandPlayActive(data) {
      return data.get('currentHand', {}).get('phase', '') == 'play';
    }

    function sessionEnrollmentActive(data) {
      return pagatHandDecisionActive(data)
        || pagatHandRevealActive(data)
        || pagatHandDrawActive(data)
        || pagatHandPlayActive(data)
        || data.get('handEnrollment', {}).get('active', false) == true
        || data.get('liveEnrollment', {}).get('active', false) == true;
    }

    function pagatHandDecisionActive(data) {
      return data.get('currentHand', {}).get('phase', '') == 'decision'
        && data.get('currentHand', {}).get('handDecision', {}).get('active', false) == true;
    }

    // Room members may drive I'm-in / timeout while enrollment is active.
    function memberEnrollmentSessionUpdate() {
      return sessionEnrollmentActive(resource.data)
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['handEnrollment', 'liveEnrollment', 'currentHand', 'updatedAt']);
    }

    // Room members open the join window from Go to Table (enrollment not active yet).
    function memberOpenEnrollmentUpdate() {
      return !sessionEnrollmentActive(resource.data)
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['handEnrollment', 'liveEnrollment', 'currentHand', 'updatedAt']);
    }

    // Room members add guests/robots to the roster while enrollment is open.
    function memberRosterSessionUpdate() {
      return request.resource.data.diff(resource.data).affectedKeys()
        .hasOnly(['players', 'liveEnrollment', 'updatedAt']);
    }

    // Client settlement after a hand (Cloud Functions optional on prod).
    // liveEnrollment.deal — nested delete when clearing legacy deal snapshots at settle.
    function memberSettlementSessionUpdate() {
      return request.resource.data.diff(resource.data).affectedKeys()
        .hasOnly([
          'handEnrollment',
          'liveEnrollment',
          'liveEnrollment.deal',
          'currentHand',
          'handCount',
          'carryOverPot',
          'dealerId',
          'pendingCoWinSettlement',
          'handStakeLocked',
          'totals',
          'rounds',
          'updatedAt',
        ]);
    }

    function memberSettlementScoreUpdate() {
      return request.resource.data.diff(resource.data).affectedKeys()
        .hasOnly([
          'net',
          'bankroll',
          'out',
          'tricksWon',
          'handsWon',
          'total',
          'skipNextAnte',
          'perHandStake',
          'updatedAt',
        ]);
    }

    function enrollmentActiveForSession(roomId, sessionId) {
      let sessionRef = /databases/$(database)/documents/rooms/$(roomId)/sessions/$(sessionId);
      return exists(sessionRef) &&
        sessionEnrollmentActive(get(sessionRef).data);
    }

    function sessionFinal(roomId, sessionId) {
      let sessionRef = /databases/$(database)/documents/rooms/$(roomId)/sessions/$(sessionId);
      return exists(sessionRef) && get(sessionRef).data.status == 'final';
    }

    function scoreLedgerFieldsChanged() {
      return request.resource.data.diff(resource.data).affectedKeys().hasAny([
        'net',
        'bankroll',
        'out',
        'tricksWon',
        'handsWon',
        'total',
        'skipNextAnte',
        'perHandStake',
      ]);
    }

    match /users/{uid} {
      allow read: if isSignedIn();
      allow write: if isUser(uid);
    }

    match /rooms/{roomId} {
      allow read: if isMember(roomId) || resource.data.ownerId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
      allow update, delete: if isRoomOwner(roomId);

      match /sessions/{sessionId} {
        allow read: if isMember(roomId);
        allow create: if isMember(roomId);
        allow update: if isMember(roomId)
          && (!sessionGameFieldsChanged()
            || memberEnrollmentSessionUpdate()
            || memberOpenEnrollmentUpdate()
            || memberRosterSessionUpdate()
            || memberSettlementSessionUpdate());
        allow delete: if isRoomOwner(roomId);

        match /scores/{scoreId} {
          allow read: if isMember(roomId);
          allow create: if isMember(roomId);
          allow update: if isMember(roomId)
            && (!scoreLedgerFieldsChanged() || memberSettlementScoreUpdate());
          allow delete: if isRoomOwner(roomId);
        }

        match /hands/{handId} {
          allow read: if isMember(roomId);
          allow create, update: if false;
          allow delete: if isRoomOwner(roomId) && sessionFinal(roomId, sessionId);
        }

        match /moneyEvents/{eventId} {
          allow read: if isMember(roomId);
          allow create: if isMember(roomId)
            && request.resource.data.eventId == eventId
            && request.resource.data.keys().hasAll(['actionId', 'type', 'sequence', 'phase']);
          allow update, delete: if false;
        }

        match /privateHands/{playerId} {
          allow read: if isMember(roomId) && (
            request.auth.uid == playerId ||
            playerId.matches('bot_.*')
          );
          allow write: if isMember(roomId) && enrollmentActiveForSession(roomId, sessionId);
          allow delete: if isMember(roomId) && (
            isRoomOwner(roomId) ||
            enrollmentActiveForSession(roomId, sessionId)
          );
        }
      }
    }

    match /inviteLookups/{code} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.ownerId == request.auth.uid;
    }

    match /roomMembers/{memberDocId} {
      function memberRoomId() {
        return resource.data.roomId != null
          ? resource.data.roomId
          : memberDocId.split('_')[0];
      }

      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isSignedIn() && (
        resource.data.userId == request.auth.uid ||
        isRoomOwner(memberRoomId())
      );
      allow delete: if isSignedIn() && (
        resource.data.userId == request.auth.uid ||
        isRoomOwner(memberRoomId())
      );
    }

    match /players/{playerId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }
  }
}
