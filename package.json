{
  "name": "national-bourre-league",
  "private": true,
  "version": "1.00.19",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "social": "npx serve docs -l 8080",
    "build:hosting": "npm run version:sync && npm run check:social && npm run build && npm run build:table && node scripts/prepare-hosting.js",
    "check:social": "node --check docs/app.js && node --check docs/auth.js && node --check docs/firestore.js",
    "build:table": "vite build --config vite.table.config.ts",
    "preview:hosting": "npm run build:hosting && npx serve dist -l 5000",
    "deploy": "npm run build:hosting && npx firebase deploy --only hosting,firestore:rules",
    "deploy:rules": "npx firebase deploy --only firestore:rules",
    "setup": "./scripts/one-time-setup.sh",
    "setup:firestore": "./scripts/setup-firestore.sh",
    "setup:webapp": "./scripts/setup-web-app.sh",
    "setup:service-account": "./scripts/setup-service-account.sh",
    "finish-setup": "./scripts/finish-deploy-setup.sh",
    "finish-setup:manual": "./scripts/finish-deploy-manual.sh",
    "setup:github-secrets": "./scripts/setup-github-secrets.sh",
    "setup:domain": "./scripts/setup-custom-domain.sh",
    "domain:finish": "./scripts/finish-domain-setup.sh",
    "domain:dns": "./scripts/apply-registrar-dns.sh",
    "setup:google-oauth": "./scripts/setup-google-oauth.sh",
    "backfill:invites": "./scripts/backfill-invite-lookups.sh",
    "version:sync": "node scripts/sync-version.js",
    "emulators": "npx firebase emulators:start --only auth,firestore --project demo-national-bourre-league"
  },
  "dependencies": {
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "firebase-tools": "^15.20.0",
    "globals": "^17.6.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12"
  }
}
